{
  "name": "@entelligentsia/pi-ollama-cloud-usage-tracker",
  "version": "1.1.0",
  "description": "Pi extension: live Ollama Cloud usage tracker in the footer with Claude-style quota bars",
  "keywords": [
    "pi-package",
    "ollama",
    "ollama-cloud",
    "usage-tracker",
    "pi-extension"
  ],
  "license": "MIT",
  "author": "Entelligentsia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Entelligentsia/pi-ollama-cloud-usage-tracker.git"
  },
  "homepage": "https://github.com/Entelligentsia/pi-ollama-cloud-usage-tracker#readme",
  "bugs": {
    "url": "https://github.com/Entelligentsia/pi-ollama-cloud-usage-tracker/issues"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "pi": {
    "extensions": ["./src/index.ts"]
  },
  "dependencies": {
    "@steipete/sweet-cookie": "^0.3.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.1.0",
